{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh pr *)",
      "Write(*)",
      "mcp__claude_ai_Atlassian__*",
      "Bash(./mvnw *)",
      "Bash(mvn *)",
      "Bash(./mvnw.cmd *)"
    ],
    "ask": [
      "Bash(git push *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(./secrets/**)"
    ]
  },
  "testing": {
    "autoRunTests": false,
    "testCommand": "./mvnw test",
    "testOnSave": false,
    "testBeforeCommit": true
  },
  "buildTool": {
    "type": "maven",
    "wrapper": true,
    "commands": {
      "clean": "./mvnw clean",
      "compile": "./mvnw compile",
      "test": "./mvnw test",
      "package": "./mvnw package",
      "install": "./mvnw install",
      "verify": "./mvnw verify"
    }
  },
  "notes": {
    "testing": "Run tests with: ./mvnw test or ./mvnw test -Dtest=TestClassName",
    "wrapper": "Maven wrapper (mvnw) should be used instead of system Maven",
    "testStrategy": "Run tests after significant changes, before commits, and when debugging"
  }
}
